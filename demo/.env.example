# Where the demo finds a wxparser node. Copy this file to demo/.env (gitignored)
# and fill in your node's address — real addresses stay out of the repo.
#
# One or more host:port candidates, space-separated, tried in order — e.g. a
# stable VPN/tailnet address first, then a LAN address as fallback:
#   WX_HOST="wxnode.example.ts.net:8080 192.0.2.10:8080"
#
# The WX_HOST environment variable, when set, takes precedence over this file.
WX_HOST=localhost:8080
